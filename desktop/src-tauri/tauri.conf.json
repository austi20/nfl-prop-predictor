{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "NFL Prop Predictor",
  "version": "0.5.0",
  "identifier": "com.nflprop.predictor",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "NFL Prop Predictor",
        "label": "main",
        "width": 1440,
        "height": 960,
        "minWidth": 1080,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi"],
    "windows": {
      "wix": {
        "language": "en-US"
      }
    },
    "externalBin": ["binaries/nfl-prop-api"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/256x256.png",
      "icons/icon.ico"
    ]
  }
}
