{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for the main desktop window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/nfl-prop-api",
          "sidecar": true,
          "args": [
            "--host",
            "127.0.0.1",
            "--port",
            {
              "validator": "\\d+"
            }
          ]
        }
      ]
    }
  ]
}
